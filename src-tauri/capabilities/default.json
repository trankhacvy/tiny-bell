{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "log:default",
    "store:default",
    "notification:default",
    "autostart:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://vercel.com/*" },
        { "url": "https://railway.app/*" },
        { "url": "https://railway.com/*" }
      ]
    }
  ]
}
