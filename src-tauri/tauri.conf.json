{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tiny Bell",
  "version": "0.1.0",
  "identifier": "com.khacvy.tiny-bell",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "desktop",
        "title": "Tiny Bell",
        "width": 560,
        "height": 680,
        "minWidth": 480,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "visible": false,
        "center": true
      },
      {
        "label": "popover",
        "title": "Tiny Bell",
        "width": 380,
        "height": 600,
        "minWidth": 380,
        "minHeight": 560,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "acceptFirstMouse": true,
        "shadow": true,
        "fullscreen": false,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://vercel.com https://*.vercel.com https://railway.app https://*.railway.app https://railway.com https://*.railway.com https://*.githubusercontent.com https://avatars.githubusercontent.com; connect-src 'self' ipc: http://ipc.localhost https://api.vercel.com https://vercel.com https://backboard.railway.app https://railway.app https://backboard.railway.com https://railway.com https://api.github.com https://github.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "publisher": "khacvy",
    "copyright": "Copyright \u00a9 2025 khacvy. All rights reserved.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
