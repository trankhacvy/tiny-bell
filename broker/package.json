{
  "name": "tiny-bell-broker",
  "version": "0.1.0",
  "private": true,
  "description": "Stateless OAuth broker for Tiny Bell. Holds provider client_secrets so they never ship in the desktop binary.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
