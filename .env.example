# ──────────────────────────────────────────────────────
# Tiny Bell — Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env.local (git-ignored) and fill in
# the values. These are injected at COMPILE TIME via
# src-tauri/build.rs — changes require a rebuild.
#
# Nothing in this file is secret: the desktop binary is
# distributed to end users, so any value embedded at
# compile time is effectively public. Client secrets live
# only in the OAuth broker (see ./broker/).
# ──────────────────────────────────────────────────────

# ── Vercel (broker-mediated OAuth) ────────────────────
# Public identifier. The matching client_secret and
# integration slug live in the broker, not here.
VERCEL_CLIENT_ID=

# ── Railway (PKCE public client) ──────────────────────
# Register a native OAuth app at:
#   https://railway.com/account/tokens (OAuth Apps tab)
# Redirect URI: http://127.0.0.1:53123/callback
RAILWAY_CLIENT_ID=

# ── GitHub (Device Flow) ──────────────────────────────
# Register an OAuth App at:
#   https://github.com/settings/developers
# Enable the "Device Flow" checkbox. No redirect URI or
# client_secret is used — device flow is public-client.
GITHUB_CLIENT_ID=

# ── OAuth broker base URL ─────────────────────────────
# Deployed Cloudflare Worker (see ./broker/). No trailing
# slash. Leave empty in dev to disable broker-mediated
# flows (users can still paste a PAT).
TINY_BELL_BROKER_BASE=
