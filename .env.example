# Vercel Integration OAuth credentials
# Register your integration at: https://vercel.com/dashboard/integrations/console
# Redirect URI must be registered as: http://127.0.0.1:53123/callback
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=

# GitHub OAuth App credentials
# Register at: https://github.com/settings/developers
